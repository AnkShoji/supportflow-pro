{
  "entities": {
    "Ticket": {
      "title": "Ticket",
      "description": "A support ticket in the system",
      "type": "object",
      "properties": {
        "title": {
          "type": "string",
          "description": "The title or description of the issue"
        },
        "status": {
          "type": "string",
          "enum": ["pending", "resolved"],
          "description": "The current status of the ticket"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the ticket was created"
        },
        "userId": {
          "type": "string",
          "description": "The ID of the user who created the ticket"
        },
        "authorName": {
          "type": "string",
          "description": "The name of the user who created the ticket"
        }
      },
      "required": ["title", "status", "createdAt", "userId"]
    },
    "User": {
      "title": "User",
      "description": "A user of the support system",
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "format": "email"
        },
        "displayName": {
          "type": "string"
        },
        "role": {
          "type": "string",
          "enum": ["user", "admin"]
        }
      },
      "required": ["email", "role"]
    }
  },
  "firestore": {
    "/tickets/{ticketId}": {
      "schema": "Ticket",
      "description": "Global collection of support tickets"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles and roles"
    }
  }
}
